rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }
    
    // Access Control Collection
    match /access_control/{userEmail} {
      // Users can read their own access document to verify permissions
      allow read: if request.auth != null && request.auth.token.email == userEmail;
      
      // Allow bootstrap admin or existing admins to write
      allow write: if request.auth != null && (
        (request.auth.token.email == userEmail && userEmail == 'noam.littvock@gmail.com') ||
        get(/databases/$(database)/documents/access_control/$(request.auth.token.email)).data.role == 'ADMIN'
      );
    }
  }
}
