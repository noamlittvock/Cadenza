rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Base permissions are Deny by Default in Firestore
    
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/access_control/$(request.auth.token.email)).data;
    }
    
    function isAdmin(userData) {
      return userData.role == 'ADMIN';
    }
    
    // Organizations collection
    match /organizations/{orgSlug} {
      allow read: if true; // Allows the app to verify if an organization exists before login
      allow write: if isAuthenticated() && request.auth.token.email == 'noam.littvock@gmail.com';
    }

    // Access Control Collection
    match /access_control/{recordId} {
      // Users can read records that belong to them, super admin can read all
      allow read: if isAuthenticated() && (
        request.auth.token.email == 'noam.littvock@gmail.com' ||
        request.auth.token.email == recordId || 
        resource.data.email == request.auth.token.email
      );
      
      // Allow bootstrap admin to write its own record, or existing admins to manage others in their org
      allow write: if isAuthenticated() && (
        request.auth.token.email == 'noam.littvock@gmail.com' ||
        (isAdmin(getUserData()) && request.method != 'delete' && getUserData().orgId == request.resource.data.orgId) ||
        (isAdmin(getUserData()) && request.method == 'delete' && getUserData().orgId == resource.data.orgId)
      );
    }
    
    // Multi-Tenant Business Data
    match /teachers/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /events/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /rooms/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /ganttBlocks/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /settings/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /lists/{id} { allow read, write: if isAuthorizedForOrg(); }
    match /customCharts/{id} { allow read, write: if isAuthorizedForOrg(); }

    function isAuthorizedForOrg() {
      return isAuthenticated() && (
        // For READ: The existing document must belong to the user's org
        (request.method == 'read' && resource.data.orgId == getUserData().orgId) ||
        // For CREATE: The new document must be assigned to the user's org
        (request.method == 'create' && request.resource.data.orgId == getUserData().orgId) ||
        // For UPDATE: Both the old and new must match the user's org
        (request.method == 'update' && resource.data.orgId == getUserData().orgId && request.resource.data.orgId == getUserData().orgId) ||
        // For DELETE: The document must belong to the user's org
        (request.method == 'delete' && resource.data.orgId == getUserData().orgId)
      );
    }
  }
}
